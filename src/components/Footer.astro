---
import Icons from './Icons.astro';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <Icons name="gamepad" size={20} />
      <span>게임인포에픽</span>
    </div>
    <p class="footer-desc">닌텐도 스위치 게임 정보 블로그</p>
    <nav class="footer-links">
      <a href="/privacy">개인정보처리방침</a>
    </nav>
    <p class="footer-copy">&copy; {year} game.infoepic.com · 무단 전재 및 재배포 금지</p>
  </div>
</footer>

<style>
.site-footer {
  background: var(--color-primary);
  color: rgba(255,255,255,0.7);
  margin-top: 5rem;
  padding-block: 2rem;
}

.footer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  text-align: center;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  color: #fff;
  font-weight: 600;
  font-size: 1rem;
}

.footer-desc {
  font-size: 0.85rem;
}

.footer-links {
  display: flex;
  gap: 1rem;
  font-size: 0.82rem;
}

.footer-links a {
  color: rgba(255,255,255,0.55);
  transition: color 0.15s;
}

.footer-links a:hover {
  color: var(--color-secondary);
}

.footer-copy {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.45);
}
</style>
