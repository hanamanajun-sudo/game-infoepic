---
// Numeric ID redirect: /12 → /entry/[slug]
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { id: String(post.data.numericId) },
    props: { slug: post.data.slug, title: post.data.title },
  }));
}

const { slug, title } = Astro.props;
const targetUrl = `/entry/${encodeURIComponent(slug)}`;
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0; url=${targetUrl}`} />
  <link rel="canonical" href={`https://game.infoepic.com/entry/${slug}/`} />
  <title>{title} | 게임인포에픽</title>
</head>
<body>
  <p>이동 중... <a href={targetUrl}>{title}</a></p>
</body>
</html>
