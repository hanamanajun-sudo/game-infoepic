---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icons from '../components/Icons.astro';

const allNews = await getCollection('news');
const newsItems = allNews
  .filter(n => n.data.raw_url)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout
  title="게임 뉴스"
  description="닌텐도 스위치 최신 게임 뉴스, 업데이트, 신작 정보 — 게임인포에픽"
  canonical="/news/"
>
  <section class="page-header">
    <div class="container">
      <h1 class="page-title">
        <Icons name="hashtag" size={24} />
        게임 뉴스
      </h1>
      <p class="page-desc">닌텐도 스위치 최신 소식을 매일 요약해 드립니다</p>
    </div>
  </section>

  <section class="news-section">
    <div class="container">
      {newsItems.length > 0 ? (
        <div class="news-list">
          {newsItems.map(item => (
            <article class="news-card">
              <div class="news-meta">
                <span class="news-source">{item.data.source}</span>
                <span class="news-date">
                  <Icons name="calendar" size={12} />
                  {new Date(item.data.date).toLocaleDateString('ko-KR', {
                    year: 'numeric', month: 'long', day: 'numeric'
                  })}
                </span>
              </div>
              <h2 class="news-title">
                {item.data.title}
              </h2>
              {item.data.description && (
                <p class="news-desc">{item.data.description}</p>
              )}
              {item.data.tags && item.data.tags.length > 0 && (
                <div class="news-tags">
                  {item.data.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
              <div class="news-actions">
                <a href={item.data.raw_url} target="_blank" rel="noopener" class="news-link">
                  원문 보기 <Icons name="external-link" size={13} />
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <Icons name="journal" size={48} />
          <p>아직 게임 뉴스가 없습니다.</p>
          <p class="empty-sub">매일 오전 9시에 자동으로 수집됩니다.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
.page-header {
  background: linear-gradient(135deg, #1a3a5c 0%, var(--color-primary) 100%);
  color: #fff;
  padding-block: 2.5rem;
}

.page-title {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1.6rem;
  font-weight: 700;
}

.page-desc {
  color: rgba(255,255,255,0.65);
  font-size: 0.9rem;
  margin-top: 0.4rem;
}

.news-section {
  padding-block: 2rem;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.news-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  transition: box-shadow 0.15s;
}

.news-card:hover {
  box-shadow: var(--shadow-sm);
}

.news-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.5rem;
  font-size: 0.78rem;
}

.news-source {
  background: var(--color-primary);
  color: #fff;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  font-weight: 600;
}

.news-date {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  color: var(--color-text-muted);
}

.news-title {
  font-size: 1.05rem;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 0.4rem;
  color: var(--color-text);
}

.news-desc {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  line-height: 1.5;
  margin-bottom: 0.5rem;
}

.news-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-bottom: 0.6rem;
}

.tag {
  font-size: 0.72rem;
  padding: 0.15rem 0.5rem;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: 999px;
  color: var(--color-text-muted);
}

.news-actions {
  display: flex;
  gap: 0.75rem;
}

.news-link {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--color-secondary);
  transition: gap 0.15s;
}

.news-link:hover {
  gap: 0.5rem;
}

.empty-state {
  text-align: center;
  padding: 4rem 1rem;
  color: var(--color-text-muted);
}

.empty-state p {
  margin-top: 0.5rem;
}

.empty-sub {
  font-size: 0.85rem;
}
</style>
